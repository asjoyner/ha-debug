#!/usr/bin/env python3
"""ha-debug: Home Assistant debugging CLI for troubleshooting automations, sensors, and light groups.

This tool queries the Home Assistant REST API to provide debugging views
that are tedious to assemble manually. It reads HASS_TOKEN and HASS_SERVER
from the environment (set them before running, or source your ha script).

Subcommands:
  timeline   Interleaved, time-sorted state history for multiple entities
  flap       Detect flapping sensors (abnormally short on/off cycles)
  trace      Show the most recent automation trace with action timestamps
  group      List member entities of a Zigbee/HA light group with status
  overlap    Find automations that control the same entity
  logbook    Human-readable logbook entries for an entity
  states     List entities matching a pattern with current state
"""

import argparse
import json
import os
import re
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timedelta, timezone

# Default paths to search for credentials
HA_SCRIPT_PATHS = [
    os.path.expanduser("~/bin/ha"),
    "/home/asjoyner/bin/ha",
]


def _load_creds_from_script():
    """Parse HASS_TOKEN and HASS_SERVER from the ha wrapper script."""
    for path in HA_SCRIPT_PATHS:
        if not os.path.isfile(path):
            continue
        try:
            with open(path) as f:
                content = f.read()
            token = None
            server = None
            for line in content.splitlines():
                m = re.match(r"""^export\s+HASS_TOKEN=['"](.*?)['"]""", line)
                if m:
                    token = m.group(1)
                m = re.match(r"""^export\s+HASS_SERVER=['"](.*?)['"]""", line)
                if m:
                    server = m.group(1)
            if token and server:
                return server, token
        except OSError:
            continue
    return None, None


def get_config():
    token = os.environ.get("HASS_TOKEN")
    server = os.environ.get("HASS_SERVER")
    if not token or not server:
        server, token = _load_creds_from_script()
    if not token or not server:
        print(
            "Error: HASS_TOKEN and HASS_SERVER not found.",
            file=sys.stderr,
        )
        print(
            "  Set env vars, or ensure ~/bin/ha exports them.", file=sys.stderr
        )
        sys.exit(1)
    return server.rstrip("/"), token


def api_get(path, params=None):
    server, token = get_config()
    url = f"{server}/api/{path}"
    if params:
        qs = "&".join(
            f"{k}={urllib.parse.quote(str(v), safe='')}"
            for k, v in params.items()
            if v is not None
        )
        if qs:
            url += f"?{qs}"
    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.reason}", file=sys.stderr)
        try:
            print(e.read().decode(), file=sys.stderr)
        except Exception:
            pass
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Connection error: {e.reason}", file=sys.stderr)
        sys.exit(1)


def api_post(path, payload):
    server, token = get_config()
    url = f"{server}/api/{path}"
    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        url,
        data=data,
        method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.reason}", file=sys.stderr)
        try:
            print(e.read().decode(), file=sys.stderr)
        except Exception:
            pass
        sys.exit(1)


def parse_since(since_str):
    """Parse a duration string like '10m', '1h', '30s' into a timedelta."""
    m = re.match(r"^(\d+)([smhd])$", since_str)
    if not m:
        print(
            f"Error: invalid duration '{since_str}'. Use e.g. 10m, 1h, 30s, 2d",
            file=sys.stderr,
        )
        sys.exit(1)
    val = int(m.group(1))
    unit = m.group(2)
    units = {"s": "seconds", "m": "minutes", "h": "hours", "d": "days"}
    return timedelta(**{units[unit]: val})


def format_ts(iso_str):
    """Format an ISO timestamp to a short local-friendly string."""
    if not iso_str:
        return "?"
    # Strip to just time portion for readability
    try:
        dt = datetime.fromisoformat(iso_str)
        return dt.strftime("%H:%M:%S.%f")[:-3]
    except Exception:
        return iso_str


def get_all_states():
    """Fetch all entity states (cached per invocation)."""
    if not hasattr(get_all_states, "_cache"):
        get_all_states._cache = api_get("states")
    return get_all_states._cache


def find_entities(pattern):
    """Find entities matching a substring or glob pattern."""
    states = get_all_states()
    results = []
    # Convert simple glob to regex
    regex_pat = pattern.replace(".", r"\.").replace("*", ".*").replace("?", ".")
    regex = re.compile(regex_pat, re.IGNORECASE)
    for s in states:
        if regex.search(s["entity_id"]):
            results.append(s)
    return results


